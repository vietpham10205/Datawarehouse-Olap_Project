  <MdxScripts>
    <MdxScript dwd:design-time-name="2548ca31-a49a-4416-ba76-ed3162488206">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/* Lệnh tính toán cơ bản cho Cube */
CALCULATE;

/* 1. Average Age */
CREATE MEMBER CURRENTCUBE.[Measures].[Average Age]
 AS IIF([Measures].[Fact Count] = 0, NULL,
    [Measures].[Age] / [Measures].[Fact Count]), 
VISIBLE = 1;

/* 2. Average Purchase Amount */
CREATE MEMBER CURRENTCUBE.[Measures].[Average Purchase Amount]
 AS IIF([Measures].[Fact Count] = 0, NULL,
    [Measures].[Purchase Amount] / [Measures].[Fact Count]), 
VISIBLE = 1;

/* 3. Average Frequency Of Purchase */
CREATE MEMBER CURRENTCUBE.[Measures].[Average Frequency Of Purchase]
 AS IIF([Measures].[Fact Count] = 0, NULL,
    [Measures].[Frequency Of Purchase] / [Measures].[Fact Count]), 
VISIBLE = 1;

/* 4. Average Brand Loyalty */
CREATE MEMBER CURRENTCUBE.[Measures].[Average Brand Loyalty]
 AS IIF([Measures].[Fact Count] = 0, NULL,
    [Measures].[Brand Loyalty] / [Measures].[Fact Count]), 
VISIBLE = 1;

/* 5. Average Product Rating */
CREATE MEMBER CURRENTCUBE.[Measures].[Average Product Rating]
 AS IIF([Measures].[Fact Count] = 0, NULL,
    [Measures].[Product Rating] / [Measures].[Fact Count]), 
VISIBLE = 1;

/* 6. Average Time Spent On Product Research */
CREATE MEMBER CURRENTCUBE.[Measures].[Average Time Spent]
 AS IIF([Measures].[Fact Count] = 0, NULL,
    [Measures].[Time Spent On Product Research] / [Measures].[Fact Count]), 
VISIBLE = 1;

/* 7. Average Return Rate */
CREATE MEMBER CURRENTCUBE.[Measures].[Average Return Rate]
 AS IIF([Measures].[Fact Count] = 0, NULL,
    [Measures].[Return Rate] / [Measures].[Fact Count]), 
VISIBLE = 1;

/* 8. Average Customer Satisfaction */
CREATE MEMBER CURRENTCUBE.[Measures].[Average Customer Satisfaction]
 AS IIF([Measures].[Fact Count] = 0, NULL,
    [Measures].[Customer Satisfaction] / [Measures].[Fact Count]), 
VISIBLE = 1;

/* 9. Average Time To Decision */
CREATE MEMBER CURRENTCUBE.[Measures].[Average Time To Decision]
 AS IIF([Measures].[Fact Count] = 0, NULL,
    [Measures].[Time To Decision] / [Measures].[Fact Count]), 
VISIBLE = 1;</Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>